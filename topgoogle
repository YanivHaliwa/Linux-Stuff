#!/usr/bin/python3

import sys
from serpapi import GoogleSearch

def search_google(query, api_key):
    params = {
        "api_key": api_key,
        "engine": "google",
        "q": query,
        "location": "United States",
        "google_domain": "google.com",
        "gl": "us",
        "hl": "en",
        "num": 15  # Limit to 15 results
    }
    search = GoogleSearch(params)
    results = search.get_dict()
    return results

def format_results(results):
    # Check if results exist
    if 'organic_results' in results:
        print('Top Results:')
        for idx, result in enumerate(results['organic_results'][:15], start=1):
            print(f'\nResult #{idx}')
            print('Title:', result.get('title', 'N/A'))
            print('Link:', result.get('link', 'N/A'))
            print('Snippet:', result.get('snippet', 'N/A'))
    else:
        print('No results found')

# Take the query from the command line arguments
if len(sys.argv) > 1:
    query = ' '.join(sys.argv[1:])  # Concatenate all arguments into a single string
else:
    print("Please provide a search query as an argument.")
    sys.exit()

# Your API key
api_key = "42a3da9c4d47d1511f9d452265817bcfd1bfced500200e98d609dc6c91fc14b9"

try:
    results = search_google(query, api_key)
    format_results(results)
except Exception as e:
    print(f"An error occurred: {e}")
    print("Please check your internet connection and API key.")